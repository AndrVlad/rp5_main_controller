#include <bits/stdc++.h>
#include <regex>
using namespace std;

int main() {
    std::string str = "+CMGL: 1,\"REC UNREAD\",\"+79123456789\",\"\",\"26/07/02,10:55:33+12\"\r\n1\r\n";

    std::regex pattern(
        R"(^\+CMGL:\s*(\d+),\"([^\"]+)\",\"([^\"]+)\",\"([^\"]*)\",\"([^\"]+)\"\r\n([^\r\n]+)\r\n)"
    );
    std::smatch match;

    std::string index, status, sender, receiver, datetime, text;

    if (std::regex_search(str, match, pattern)) {
        index = match[1].str();
        status = match[2].str();
        sender = match[3].str();
        receiver = match[4].str();
        datetime = match[5].str();
        text = match[6].str();
        
        std::cout << "Индекс: " << index << std::endl;
        std::cout << "Статус: " << status << std::endl;
        std::cout << "Отправитель: " << sender << std::endl;
        std::cout << "Получатель:" << receiver << std::endl;
        std::cout << "Дата, время:" << datetime << std::endl;
        std::cout << "Текст:" << text << std::endl;
    } else {
        std::cerr << "Ошибка: строка не соответствует формату +CMGL" << std::endl;
    }
    
    return 0;
}
